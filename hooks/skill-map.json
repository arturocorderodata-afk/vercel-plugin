        "next-env.d.ts",
        "app/**",
        "pages/**",
        "src/app/**",
        "src/pages/**",
        "tailwind.config.*",
        "postcss.config.*",
        "tsconfig.json",
        "tsconfig.*.json"
      ],
      "bashPatterns": [
        "\\bnext\\s+(dev|build|start|lint)\\b",
        "\\bnpx\\s+create-next-app\\b",
        "\\bbunx\\s+create-next-app\\b"
      ]
    },
    "ai-sdk": {
      "pathPatterns": [
